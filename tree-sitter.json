{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "metasp",
      "camelcase": "Metasp",
      "title": "Metasp",
      "scope": "source.metasp",
      "file-types": [
        "lp"
      ],
      "injection-regex": "^metasp$",
      "class-name": "TreeSitterMetasp",
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "Metasp grammar for tree-sitter",
    "authors": [
      {
        "name": "Roland Kaminski"
      },
      {
        "name": "Sven Thiele"
      }
    ],
    "links": {
      "repository": "https://github.com/potassco/tree-sitter-metasp"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false
  }
}
